# Application
APP_ENV=development
APP_NAME=AI Hospital Command Center
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/hospital_command_center.db

# LLM (configure provider as needed)
OPENAI_API_KEY=
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0.2

# Streamlit
STREAMLIT_SERVER_PORT=8501

# Channels (optional)
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
